# Copier en `.env` à côté du docker-compose*.yml, puis remplir.

# --- Sécurité admin (OBLIGATOIRE) ---
ADMIN_PASSWORD=changez-moi
ADMIN_TOKEN_SECRET=une-longue-chaine-aleatoire

# --- URL publique du site (liens PDF/images envoyés sur WhatsApp) ---
# En local : http://localhost:8080 — en prod : https://votre-domaine.sn
PUBLIC_URL=http://localhost:8080

# --- Port exposé par le front (nginx) ---
FRONT_PORT=8080

# --- Production uniquement (docker-compose.prod.yml) ---
# Préfixe des images publiées par la CI sur GitHub Container Registry :
# ghcr.io/<votre-user-github>/<nom-du-repo>
IMAGE_PREFIX=ghcr.io/mon-user/mon-repo
TAG=latest
